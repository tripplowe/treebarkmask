# Copy to .env and edit for your machine:  cp .env.example .env
# Absolute host paths (no trailing slash).

# Directory containing your bark photos (read-only mount).
INPUT_DIR=/path/to/Southern_Bark_Photos

# Directory where outputs are written. Results land in $OUTPUT_DIR/out/
# (masks/, review/, cutouts/, manifest_shard*.csv).
OUTPUT_DIR=/path/to/your/workdir

# Directory holding the downloaded SAM 3 checkpoint (must contain sam3.pt + config.json).
CKPT_DIR=/path/to/sam3_ckpt

# Your host user so output files are owned by you, not root.
# Fill these with the output of `id -u` and `id -g`, e.g.:
HOST_UID=1000
HOST_GID=1000
